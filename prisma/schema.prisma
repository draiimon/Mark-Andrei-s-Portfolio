// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            Int      @id @default(autoincrement())
  fullName      String
  headline      String
  location      String
  email         String
  phone         String
  github        String
  linkedinUrl   String?
  facebookUrl   String?
  objective     String
  about         String
  skills        String
  availability  String?  /// e.g. "Available for work · Philippines"
  brandName     String?  /// e.g. "To the clouds."
  heroTagline   String?  /// e.g. "builds in the cloud."
  tabTitle      String?
  faviconUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  tagline     String
  description String
  techStack   String
  link        String?  /// Live demo URL
  githubUrl   String?  /// GitHub repo URL
  highlight   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  createdAt DateTime @default(now())
}

model Resume {
  id        Int      @id @default(autoincrement())
  fileName  String   @default("resume.pdf")
  content   Bytes
  updatedAt DateTime @updatedAt
}

model Experience {
  id        Int      @id @default(autoincrement())
  role      String
  company   String
  period    String
  summary   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Leadership {
  id        Int      @id @default(autoincrement())
  org       String
  role      String
  period    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tagline {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

