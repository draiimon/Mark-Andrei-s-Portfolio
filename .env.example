# Database
DATABASE_URL="postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require"

# AI
GROQ_API_KEY="gsk_..."

# Admin login (used by /edit)
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-admin-password"

# Metadata base URL (used for OpenGraph/Twitter absolute URLs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional (kept for compatibility if needed later)
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
